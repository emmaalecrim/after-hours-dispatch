# Contentful Configuration
# Copy this file to .env and fill in your values
PUBLIC_CONTENTFUL_CONTENT_TYPE=blogPost
# Your Contentful Space ID
PUBLIC_CONTENTFUL_SPACE_ID=

# Your Contentful Content Delivery API access token
PUBLIC_CONTENTFUL_ACCESS_TOKEN=

# Your Contentful Management API access token (for seeding data)
# Get this from: https://app.contentful.com/spaces/YOUR_SPACE_ID/api/keys
CONTENTFUL_MANAGEMENT_TOKEN=

# Your Contentful environment (defaults to "master")
PUBLIC_CONTENTFUL_ENVIRONMENT=master

# Site configuration
SITE_URL=

