# Contentful Configuration
# Copy this file to .env for local development. When deploying to Cloudflare
# Workers, only the access token must be kept secret — set it using
# `wrangler secret put CONTENTFUL_ACCESS_TOKEN`.

# Non-secret configuration (can be stored in your Workers `wrangler.toml`
# under `[vars]` or provided via environment for local development):
CONTENTFUL_SPACE_ID=your_space_id_here
CONTENTFUL_CONTENT_TYPE=post
CONTENTFUL_ENVIRONMENT=master

# Secret (store this with `wrangler secret put CONTENTFUL_ACCESS_TOKEN`):
CONTENTFUL_ACCESS_TOKEN=

# Site configuration
SITE_URL=

